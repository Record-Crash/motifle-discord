# Discord application credentials
# Find these at: https://discord.com/developers/applications → your app
VITE_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# Public URL of this server (used for embed preview image links sent by the bot)
VITE_SERVER_BASE=https://your-domain.com

# CDN root for audio/images — leave empty to serve from Express (recommended)
VITE_STATIC_BASE=

# Port Express listens on (default: 3001)
PORT=3001
