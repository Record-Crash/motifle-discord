VITE_DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID_HERE
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET

# Bot token for posting channel messages and daily summaries.
# Developer Portal → Bot → Reset Token. Invite bot via OAuth2 URL Generator
# with bot scope + Send Messages + Embed Links permissions.
DISCORD_BOT_TOKEN=

# Ed25519 public key for verifying interaction button signatures.
# Developer Portal → General Information → Public Key.
# Also set Interactions Endpoint URL → https://your-server/api/interactions
DISCORD_PUBLIC_KEY=

# Base URL for static assets (audio + images).
# Leave empty for local dev (files served by Express at /audio/ and /images/).
# Set to CDN root for production (no trailing slash).
# Example: VITE_STATIC_BASE=https://static.recordcrash.com/motifle
VITE_STATIC_BASE=

# Public base URL of the Express server, used to build embed preview image URLs.
# Leave empty for local dev (Discord cannot reach localhost, so setActivity previews won't show).
# Set to your deployed server URL for production (no trailing slash).
# Example: VITE_SERVER_BASE=https://motifle-server.fly.dev
VITE_SERVER_BASE=